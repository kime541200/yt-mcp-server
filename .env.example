# ============================================================
# YouTube MCP Server — 環境變數範例文件
# 複製此文件為 .env 並填入您的真實金鑰
# ============================================================

# ----- YouTube Data API Keys -----
# 至少需要設定一把 API Key，系統會在 Quota 耗盡時自動輪替
YOUTUBE_API_KEY=your_youtube_api_key_here
# YOUTUBE_API_KEY2=your_second_api_key_here   # 選填：第二把 Key（輪替用）
# YOUTUBE_API_KEY3=your_third_api_key_here    # 選填：第三把 Key（輪替用）

# ----- MCP Server 設定 -----
MCP_HOST=0.0.0.0
MCP_PORT=8088
MCP_TRANSPORT=http    # http | stdio
